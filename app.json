{
  "expo": {
    "name": "Ford Radar",
    "slug": "ford-radar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#080D14"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ford.radar"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080D14"
      },
      "package": "com.ford.radar"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
